{
  "expo": {
    "name": "Vitality Prep",
    "slug": "vitality-prep",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "vitalityprep",
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Vitality Prep",
      "shortName": "VitalityPrep",
      "description": "Meal prep recipes, planner & shopping list for two.",
      "themeColor": "#4d6054",
      "backgroundColor": "#f7faf5",
      "display": "standalone",
      "lang": "de",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
