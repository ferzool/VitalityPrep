rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Recipe images: anyone signed in can read; users can only write into
    // their own folder. 10 MB cap covers modern phone photos at quality 0.8.
    match /recipe-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
