rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The two webauthn collections are server-only (admin SDK bypasses rules).
    // Reject all client access.
    match /_webauthn_credentials/{document=**} {
      allow read, write: if false;
    }
    match /_webauthn_challenges/{document=**} {
      allow read, write: if false;
    }

    // Any authenticated user (Iman or Niloo) has full read/write on the app data.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
